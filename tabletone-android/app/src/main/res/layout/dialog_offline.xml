<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@drawable/dialog_bg">

    <!-- Иконка -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="📡"
        android:textSize="48sp"
        android:layout_marginBottom="16dp"/>

    <!-- Заголовок -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Вы не в сети!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <!-- Описание -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Кажется, вы не в сети. Для работы с мессенджером необходимо быть в стабильном интернете. Подключитесь к стабильному интернету и попробуйте ещё раз!"
        android:textSize="14sp"
        android:textColor="#A0AEC0"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="24dp"/>

    <!-- Кнопка -->
    <Button
        android:id="@+id/btn_retry"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Я в сети"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/btn_primary"
        android:stateListAnimator="@null"/>

</LinearLayout>
