# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Flask
SECRET_KEY=change-me-to-a-random-string

# База данных (по умолчанию SQLite, для продакшена — PostgreSQL)
DATABASE_URL=sqlite:///messenger.db

# Telegram боты
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
PAYMENT_BOT_TOKEN=your-payment-bot-token

# Telegram владелец (chat_id для уведомлений)
OWNER_TELEGRAM_ID=0

# Платёжные реквизиты
CARD_NUMBER=+7XXXXXXXXXX
CARD_BANK=СБП / любой банк

# Секрет для платёжного вебхука
PAYMENT_SECRET=change-me-to-random-secret

# URL сайта (для вебхуков)
SITE_URL=https://your-app.onrender.com

# Gemini API (для AI-функций, необязательно)
GEMINI_API_KEY=
