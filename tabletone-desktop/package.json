{
  "name": "tabletone",
  "version": "1.0.0",
  "description": "Tabletone Messenger",
  "author": "Tabletone",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.tabletone.app",
    "productName": "Tabletone",
    "win": {
      "target": "nsis",
      "icon": "../static/images/logo.png",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
