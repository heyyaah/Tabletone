{
  "name": "tabletone-installer",
  "version": "1.0.0",
  "description": "Tabletone Installer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.tabletone.installer",
    "productName": "Tabletone Setup",
    "win": {
      "target": [{ "target": "portable", "arch": ["x64"] }],
      "icon": "icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "portable": {
      "artifactName": "Tabletone Setup 1.0.0.exe"
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [
      {
        "from": "../dist/win-unpacked",
        "to": "app",
        "filter": ["**/*"]
      }
    ],
    "publish": null
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
